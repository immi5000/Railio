.claude
CLAUDE.md

.research

# env files — never commit
.env
.env.*
!.env.example
!.env.*.example

# local data / uploads
.railio.db
.railio.db-journal
.railio-uploads/

# build output / deps
node_modules/
.next/
*.tsbuildinfo
.vercel

# Only frontend/ is a JS project. A package-lock.json anywhere else is a stray
# (e.g. an accidental `npm install` in the repo root or the Python backend); it
# makes Turbopack infer the wrong workspace root and pull the whole monorepo
# into its cache, which freezes the dev server. Ignore lockfiles everywhere
# except frontend/ so they can never be committed again.
package-lock.json
!frontend/package-lock.json

# outreach script — kept local, not part of the app
outreach/email_outreach.py

# isolated admin ingestion tool — secrets + heavy outputs (the code is tracked,
# but it must never enter the backend/frontend deploy contexts)
railio-ingest/.env
railio-ingest/.env.*
!railio-ingest/.env.example
railio-ingest/out/
railio-ingest/.venv/



