# === Supabase Postgres (DB) ===
# Settings → Database → Connect → URI tab → "Transaction pooler" (port 6543).
# Serverless functions MUST use the pooler; the direct 5432 connection runs out of slots.
DATABASE_URL=

# Direct connection (port 5432, host db.<ref>.supabase.co). Used by db:migrate and
# db:seed* scripts to bypass the pooler's per-statement timeout. Optional — if unset,
# scripts fall back to DATABASE_URL.
DATABASE_URL_DIRECT=

# === Supabase Storage (file uploads + form PDFs) ===
# Settings → API → Project URL.
SUPABASE_URL=
# Settings → API → service_role secret (or new key system: a `sb_secret_…` key).
# SERVER-ONLY. Never expose to the browser; never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# === OpenAI (chat model + default embeddings) ===
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Chat / tool-use model. Must support function calling, vision, streaming.
OPENAI_CHAT_MODEL=gpt-4o

# === Embeddings (corpus retrieval) ===
# Output dimension MUST be 1024 to match corpus_chunks.embedding (vector(1024)).
EMBEDDINGS_PROVIDER=openai            # 'openai' | 'voyage' | 'cohere'
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large   # truncated to 1024 dims via `dimensions` param
VOYAGE_API_KEY=
COHERE_API_KEY=

# === Optional reranker (skip in v0 if cost is a concern) ===
RERANKER_ENABLED=false
RERANKER_MODEL=rerank-3

# === Server ===
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
