OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o

EMBEDDINGS_PROVIDER=openai
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large
VOYAGE_API_KEY=
COHERE_API_KEY=

PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# Supabase Postgres (transaction pooler — port 6543)
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-1-us-east-2.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — used by scripts to avoid pooler statement timeout
DATABASE_URL_DIRECT=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
