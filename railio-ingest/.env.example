# Copy to .env and fill with PROD credentials. This file (.env) is gitignored.
# The tool writes directly into the production Supabase — handle with care.

# Prod Postgres (Supabase). Use the same DATABASE_URL the backend uses.
# Transaction-pooler URLs (port 6543) are handled (statement_cache_size=0).
DATABASE_URL=

# Prod Supabase storage (for figure PNG uploads). Same values as backend/.env.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — used for BOTH the gpt-4o vision/captioning pass and 1024-dim embeddings.
OPENAI_API_KEY=

# Optional overrides (defaults match prod):
OPENAI_VISION_MODEL=gpt-4o
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large
